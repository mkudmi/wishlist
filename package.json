{
  "name": "birthday-wishlist",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "seo:sync": "node scripts/sync-seo-assets.js",
    "predev": "npm run seo:sync",
    "prebuild": "npm run seo:sync",
    "dev": "vite --host 127.0.0.1 --port 5173 --open /",
    "dev:all": "concurrently -k -n frontend,backend \"npm run dev\" \"npm run server:dev\"",
    "build": "vite build && npm run prerender",
    "prerender": "tsx scripts/prerender.jsx",
    "preview": "vite preview",
    "server:dev": "node --watch backend/src/index.js",
    "server:start": "node backend/src/index.js",
    "db:migrate": "node backend/scripts/migrate.js",
    "db:seed": "node backend/scripts/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.11"
  }
}
